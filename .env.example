PORT=3000
DATABASE_HOST=localhost
PORT_DB=5432
DATABASE_NAME=postgres
USERNAME_DB=postgres
DATABASE_PASSWORD=postgres
DATABASE_SYNCHRONIZE=true
DATABASE_DROP_SCHEMA=false
DATABASE_LOGGING=false
JWT_SECRET=change-me-in-local-env
UPLOAD_DIR=/uploads
MAX_IMAGE_MB=5
APP_NAME=Mi Ecommerce
EMAIL_VERIFICATION_URL_BASE=http://localhost:5173/verify-email?token=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=replace-with-app-password
EMAIL_FROM=Mi App <your-email@example.com>

# Frontend base URL (used for invitation emails)
FRONTEND_URL=http://localhost:5173

# Cloudinary (https://cloudinary.com → Dashboard)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
